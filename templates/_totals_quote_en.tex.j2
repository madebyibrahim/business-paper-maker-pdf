% Reusable totals block for English-only QUOTATION.
% Always right-aligned via flushright; ends with a forced \par so any text
% that follows (e.g. exchange-rate note) starts on its own line.
\vspace{6pt}
\begin{flushright}
\begin{minipage}{8cm}
\renewcommand{\arraystretch}{1.25}
\begin{tabular*}{\linewidth}{@{}l@{\extracolsep{\fill}}r@{}}
\textbf{Subtotal} & \$<<totals.subtotal>> \\
((* if totals.discount_pct *))
\textbf{Discount (<<totals.discount_pct>>\%)} & -\$<<totals.discount_amount>> \\
((* endif *))
((* if totals.tax_pct *))
\textbf{Tax (<<totals.tax_pct>>\%)} & \$<<totals.tax_amount>> \\
((* endif *))
\arrayrulecolor{accent}\midrule
\multicolumn{2}{@{}r@{}}{\colorbox{accent}{\parbox{\dimexpr\linewidth-2\fboxsep\relax}{%
  \color{white}\begin{tabular*}{\linewidth}{@{}l@{\extracolsep{\fill}}r@{}}%
    \textbf{\large TOTAL} & \textbf{\large \$<<totals.grand_total>>}%
  \end{tabular*}%
}}}\\
\end{tabular*}
\end{minipage}
\end{flushright}
